<script>
// ── STATE ──
const fields = {};
const costs = [];
const benefits = [];
const risks = [];
const stakeholders = [];
let itemModalType = 'cost';

const AVATAR_COLORS = ['#7c6fcd','#5a9e7a','#4a8bc4','#c4854a','#c03030','#3a9ebf','#c45a8a'];
const STATUSES = [
  { key: 'draft',    label: 'Draft',    cls: 'status-draft'    },
  { key: 'review',   label: 'In Review',cls: 'status-review'   },
  { key: 'approved', label: 'Approved', cls: 'status-approved' },
];
let statusIdx = 0;

// ── EDITABLE FIELDS ──
function activateField(key) {
  const display = document.getElementById('f-' + key);
  const input   = document.getElementById('fi-' + key);
  display.style.display = 'none';
  input.style.display = 'block';
  input.value = fields[key] || '';
  input.focus();
}

function deactivateField(key) {
  const display = document.getElementById('f-' + key);
  const input   = document.getElementById('fi-' + key);
  const val = input.value.trim();
  fields[key] = val;
  input.style.display = 'none';
  display.style.display = 'block';
  if (val) {
    display.textContent = val;
    display.classList.remove('empty');
  } else {
    display.textContent = display.dataset.placeholder;
    display.classList.add('empty');
  }
}

function saveField(key) {
  fields[key] = document.getElementById('fi-' + key).value;
  updateTimestamp();
}

// ── STATUS ──
function cycleStatus() {
  statusIdx = (statusIdx + 1) % STATUSES.length;
  const s = STATUSES[statusIdx];
  const chip = document.getElementById('doc-status-chip');
  chip.className = 'status-chip ' + s.cls;
  chip.innerHTML = `<span class="status-chip-dot"></span>${s.label}`;
}

// ── TIMESTAMP ──
function updateTimestamp() {
  document.querySelector('.page-header-actions span').innerHTML =
    'Last edited <strong style="color:var(--text2)">just now</strong>';
}

// ── MODAL ──
function openModal(type) {
  itemModalType = type;
  if (type === 'cost' || type === 'benefit') {
    document.getElementById('item-modal-title').textContent = type === 'cost' ? 'Add Cost Item' : 'Add Benefit Item';
    document.getElementById('item-desc').value = '';
    document.getElementById('item-cat').value  = '';
    document.getElementById('item-amount').value = '';
    document.getElementById('item-modal').style.display = 'flex';
    setTimeout(() => document.getElementById('item-desc').focus(), 50);
  } else if (type === 'risk') {
    document.getElementById('risk-desc').value = '';
    document.getElementById('risk-likelihood').value = 'medium';
    document.getElementById('risk-impact').value = 'medium';
    document.getElementById('risk-modal').style.display = 'flex';
    setTimeout(() => document.getElementById('risk-desc').focus(), 50);
  } else if (type === 'stakeholder') {
    document.getElementById('sh-name').value = '';
    document.getElementById('sh-role').value = '';
    document.getElementById('stakeholder-modal').style.display = 'flex';
    setTimeout(() => document.getElementById('sh-name').focus(), 50);
  }
}

function closeModal(id, e) {
  if (e.target === document.getElementById(id))
    document.getElementById(id).style.display = 'none';
}

function saveItemModal() {
  const desc   = document.getElementById('item-desc').value.trim();
  const cat    = document.getElementById('item-cat').value.trim();
  const amount = parseFloat(document.getElementById('item-amount').value) || 0;
  if (!desc) { document.getElementById('item-desc').focus(); return; }

  const id = Date.now();
  if (itemModalType === 'cost') {
    costs.push({ id, desc, cat, amount });
    renderCosts();
  } else {
    benefits.push({ id, desc, cat, amount });
    renderBenefits();
  }
  document.getElementById('item-modal').style.display = 'none';
  updateMetrics();
  updateTimestamp();
}

function saveRiskModal() {
  const desc = document.getElementById('risk-desc').value.trim();
  if (!desc) { document.getElementById('risk-desc').focus(); return; }
  risks.push({
    id: Date.now(),
    desc,
    likelihood: document.getElementById('risk-likelihood').value,
    impact: document.getElementById('risk-impact').value,
  });
  renderRisks();
  document.getElementById('risk-modal').style.display = 'none';
  updateTimestamp();
}

function saveStakeholderModal() {
  const name = document.getElementById('sh-name').value.trim();
  if (!name) { document.getElementById('sh-name').focus(); return; }
  stakeholders.push({
    id: Date.now(),
    name,
    role: document.getElementById('sh-role').value.trim(),
    color: AVATAR_COLORS[stakeholders.length % AVATAR_COLORS.length],
  });
  renderStakeholders();
  document.getElementById('stakeholder-modal').style.display = 'none';
  updateTimestamp();
}

// ── RENDERERS ──
function fmt(n) {
  if (n === 0) return '$0';
  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}

function renderCosts() {
  const container = document.getElementById('cost-rows');
  container.innerHTML = '';
  costs.forEach(c => {
    const row = document.createElement('div');
    row.className = 'table-row';
    row.style.gridTemplateColumns = '1fr 100px 22px';
    row.innerHTML = `
      <div>
        <div class="table-row-text">${c.desc}</div>
        ${c.cat ? `<div class="table-row-sub">${c.cat}</div>` : ''}
      </div>
      <div class="table-row-amount" style="color:var(--c5)">${fmt(c.amount)}</div>
      <button class="table-row-delete" onclick="deleteItem('cost', ${c.id})">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    `;
    container.appendChild(row);
  });
  const total = costs.reduce((s, c) => s + c.amount, 0);
  document.getElementById('costs-total').textContent = costs.length ? fmt(total) : '—';
}

function renderBenefits() {
  const container = document.getElementById('benefit-rows');
  container.innerHTML = '';
  benefits.forEach(b => {
    const row = document.createElement('div');
    row.className = 'table-row';
    row.style.gridTemplateColumns = '1fr 100px 22px';
    row.innerHTML = `
      <div>
        <div class="table-row-text">${b.desc}</div>
        ${b.cat ? `<div class="table-row-sub">${b.cat}</div>` : ''}
      </div>
      <div class="table-row-amount" style="color:var(--c2)">${fmt(b.amount)}</div>
      <button class="table-row-delete" onclick="deleteItem('benefit', ${b.id})">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    `;
    container.appendChild(row);
  });
  const total = benefits.reduce((s, b) => s + b.amount, 0);
  document.getElementById('benefits-total').textContent = benefits.length ? fmt(total) : '—';
}

function renderRisks() {
  const container = document.getElementById('risk-rows');
  container.innerHTML = '';
  risks.forEach(r => {
    const row = document.createElement('div');
    row.className = 'risk-row';
    row.innerHTML = `
      <div class="table-row-text">${r.desc}</div>
      <div style="text-align:center"><span class="risk-badge risk-${r.likelihood}">${r.likelihood}</span></div>
      <div style="text-align:center"><span class="risk-badge risk-${r.impact}">${r.impact}</span></div>
      <button class="table-row-delete" onclick="deleteRisk(${r.id})">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    `;
    container.appendChild(row);
  });
}

function renderStakeholders() {
  const container = document.getElementById('stakeholder-list');
  if (!stakeholders.length) {
    container.innerHTML = '<span style="font-size:12px; color:var(--text3); font-style:italic; padding:4px 2px;">No stakeholders added yet.</span>';
    return;
  }
  container.innerHTML = '';
  stakeholders.forEach(s => {
    const initials = s.name.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
    const chip = document.createElement('div');
    chip.className = 'stakeholder-chip';
    chip.innerHTML = `
      <div class="stakeholder-avatar" style="background:${s.color}">${initials}</div>
      <span>${s.name}${s.role ? ` · <span style="color:var(--text3)">${s.role}</span>` : ''}</span>
      <button class="stakeholder-remove" onclick="deleteStakeholder(${s.id})" title="Remove">×</button>
    `;
    container.appendChild(chip);
  });
}

// ── DELETE ──
function deleteItem(type, id) {
  if (type === 'cost') {
    const i = costs.findIndex(c => c.id === id);
    if (i > -1) costs.splice(i, 1);
    renderCosts();
  } else {
    const i = benefits.findIndex(b => b.id === id);
    if (i > -1) benefits.splice(i, 1);
    renderBenefits();
  }
  updateMetrics();
  updateTimestamp();
}

function deleteRisk(id) {
  const i = risks.findIndex(r => r.id === id);
  if (i > -1) risks.splice(i, 1);
  renderRisks();
  updateTimestamp();
}

function deleteStakeholder(id) {
  const i = stakeholders.findIndex(s => s.id === id);
  if (i > -1) stakeholders.splice(i, 1);
  renderStakeholders();
  updateTimestamp();
}

// ── METRICS ──
function updateMetrics() {
  const totalCost    = costs.reduce((s, c) => s + c.amount, 0);
  const totalBenefit = benefits.reduce((s, b) => s + b.amount, 0);
  const netValue     = totalBenefit - totalCost;
  const roi          = totalCost > 0 ? ((netValue / totalCost) * 100).toFixed(0) : null;

  const costEl    = document.getElementById('metric-total-cost');
  const benEl     = document.getElementById('metric-total-benefit');
  const netEl     = document.getElementById('metric-net-value');
  const roiEl     = document.getElementById('metric-roi');

  costEl.textContent = (costs.length || benefits.length) ? fmt(totalCost) : '—';
  benEl.textContent  = (costs.length || benefits.length) ? fmt(totalBenefit) : '—';

  if (costs.length || benefits.length) {
    netEl.textContent = fmt(netValue);
    netEl.className   = 'metric-value ' + (netValue >= 0 ? 'metric-positive' : 'metric-negative');
    roiEl.textContent = roi !== null ? roi + '%' : '—';
    roiEl.className   = 'metric-value ' + (roi !== null ? (parseFloat(roi) >= 0 ? 'metric-positive' : 'metric-negative') : '');
  } else {
    netEl.textContent = '—';
    netEl.className   = 'metric-value';
    roiEl.textContent = '—';
    roiEl.className   = 'metric-value';
  }
}

