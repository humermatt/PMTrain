// ── APPROVER ──
function toggleApproverPopout() {
  const popout = document.getElementById('approver-popout');
  const isOpen = popout.style.display === 'block';
  if (isOpen) {
    closeApproverPopout();
  } else {
    const current = document.getElementById('approver-name').textContent;
    document.getElementById('approver-input').value = current === 'None' ? '' : current;
    popout.style.display = 'block';
    setTimeout(() => document.getElementById('approver-input').focus(), 50);
  }
}

function closeApproverPopout() {
  document.getElementById('approver-popout').style.display = 'none';
}

function saveApprover() {
  const name = document.getElementById('approver-input').value.trim();
  document.getElementById('approver-name').textContent = name || 'None';
  document.getElementById('approver-name').style.color = name ? 'var(--text)' : 'var(--text2)';
  closeApproverPopout();
  if (name) updateTimestamp();
}

function clearApprover() {
  document.getElementById('approver-input').value = '';
  document.getElementById('approver-name').textContent = 'None';
  document.getElementById('approver-name').style.color = 'var(--text2)';
  closeApproverPopout();
}

// Close approver popout when clicking outside
document.addEventListener('mousedown', e => {
  const wrap = document.getElementById('approver-wrap');
  if (wrap && !wrap.contains(e.target)) closeApproverPopout();
});

