// ── DOCUMENTS ──
const docs = [];
let editingDocId = null;

const DOC_TYPES = {
  note:       { label: 'Note',       emoji: '📝', color: '#7c6fcd', light: 'rgba(124,111,205,0.12)' },
  decision:   { label: 'Decision',   emoji: '✅', color: '#5a9e7a', light: 'rgba(90,158,122,0.12)'  },
  meeting:    { label: 'Meeting',    emoji: '🗓', color: '#4a8bc4', light: 'rgba(74,139,196,0.12)'  },
  reference:  { label: 'Reference',  emoji: '🔗', color: '#c4854a', light: 'rgba(196,133,74,0.12)'  },
  attachment: { label: 'Attachment', emoji: '📎', color: '#888780', light: 'rgba(136,135,128,0.12)' },
};

function onDocTypeChange() {
  const type = document.getElementById('doc-type').value;
  const isRef = type === 'reference' || type === 'attachment';
  document.getElementById('doc-content-field').style.display = isRef ? 'none' : 'flex';
  document.getElementById('doc-url-field').style.display     = isRef ? 'flex' : 'none';
  document.getElementById('doc-content').placeholder =
    type === 'meeting'  ? 'Attendees, agenda, key outcomes…'  :
    type === 'decision' ? 'What was decided and why?'         :
    'Write your note or details here…';
}

function saveDocModal() {
  const type    = document.getElementById('doc-type').value;
  const title   = document.getElementById('doc-title').value.trim();
  const content = document.getElementById('doc-content').value.trim();
  const url     = document.getElementById('doc-url').value.trim();
  const isRef   = type === 'reference' || type === 'attachment';
  if (!title) { document.getElementById('doc-title').focus(); return; }
  if (isRef && !url && !content) { document.getElementById('doc-url').focus(); return; }

  docs.push({ id: Date.now(), type, title, content, url });
  renderDocs();
  document.getElementById('doc-modal').style.display = 'none';
  updateTimestamp();
}

function openDocEdit(id) {
  const doc = docs.find(d => d.id === id);
  if (!doc) return;
  editingDocId = id;
  const isRef = doc.type === 'reference' || doc.type === 'attachment';
  document.getElementById('doc-edit-title').value   = doc.title;
  document.getElementById('doc-edit-content').value = doc.content || '';
  document.getElementById('doc-edit-url').value     = doc.url || '';
  document.getElementById('doc-edit-content-field').style.display = isRef ? 'none' : 'flex';
  document.getElementById('doc-edit-url-field').style.display     = isRef ? 'flex' : 'none';
  document.getElementById('doc-edit-modal').style.display = 'flex';
  setTimeout(() => document.getElementById('doc-edit-title').focus(), 50);
}

function saveDocEdit() {
  const doc = docs.find(d => d.id === editingDocId);
  if (!doc) return;
  doc.title   = document.getElementById('doc-edit-title').value.trim() || doc.title;
  doc.content = document.getElementById('doc-edit-content').value.trim();
  doc.url     = document.getElementById('doc-edit-url').value.trim();
  renderDocs();
  document.getElementById('doc-edit-modal').style.display = 'none';
  editingDocId = null;
  updateTimestamp();
}

function deleteDoc(id) {
  const i = docs.findIndex(d => d.id === id);
  if (i > -1) docs.splice(i, 1);
  renderDocs();
  updateTimestamp();
}

function renderDocs() {
  const list    = document.getElementById('doc-list');
  const empty   = document.getElementById('doc-list-empty');
  list.innerHTML = '';
  if (!docs.length) { empty.style.display = 'block'; return; }
  empty.style.display = 'none';

  docs.forEach(doc => {
    const t    = DOC_TYPES[doc.type] || DOC_TYPES.note;
    const isRef = doc.type === 'reference' || doc.type === 'attachment';
    const card = document.createElement('div');
    card.className = 'doc-card';
    card.innerHTML = `
      <div class="doc-icon" style="background:${t.light}; color:${t.color}; font-size:17px;">${t.emoji}</div>
      <div class="doc-card-body">
        <div class="doc-card-title">${doc.title}</div>
        ${doc.content ? `<div class="doc-card-content">${doc.content}</div>` : ''}
        ${isRef && doc.url ? `<div class="doc-card-content"><a href="${doc.url}" target="_blank" style="color:var(--accent); text-decoration:none; word-break:break-all;">${doc.url}</a></div>` : ''}
        <div class="doc-card-meta">
          <span class="doc-type-badge" style="background:${t.light}; color:${t.color}; border-color:${t.color}33;">${t.label}</span>
        </div>
      </div>
      <div class="doc-card-actions">
        <button class="doc-action-btn" onclick="openDocEdit(${doc.id})" title="Edit">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </button>
        <button class="doc-action-btn danger" onclick="deleteDoc(${doc.id})" title="Delete">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    `;
    list.appendChild(card);
  });
}

// extend openModal to handle 'doc'
const _origOpenModal = openModal;
openModal = function(type) {
  if (type === 'doc') {
    document.getElementById('doc-type').value   = 'note';
    document.getElementById('doc-title').value  = '';
    document.getElementById('doc-content').value = '';
    document.getElementById('doc-url').value    = '';
    onDocTypeChange();
    document.getElementById('doc-modal').style.display = 'flex';
    setTimeout(() => document.getElementById('doc-title').focus(), 50);
    return;
  }
  _origOpenModal(type);
};

// extend keyboard handler for new modals
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.getElementById('doc-modal').style.display = 'none';
    document.getElementById('doc-edit-modal').style.display = 'none';
  }
  if (e.key === 'Enter' && !e.shiftKey && document.activeElement.tagName !== 'TEXTAREA') {
    if (document.getElementById('doc-modal').style.display === 'flex') { e.preventDefault(); saveDocModal(); }
    if (document.getElementById('doc-edit-modal').style.display === 'flex') { e.preventDefault(); saveDocEdit(); }
  }
}, true);

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    ['item-modal','risk-modal','stakeholder-modal'].forEach(id => {
      document.getElementById(id).style.display = 'none';
    });
  }
  const activeModal = ['item-modal','risk-modal','stakeholder-modal']
    .find(id => document.getElementById(id).style.display === 'flex');
  if (activeModal && e.key === 'Enter' && !e.shiftKey && document.activeElement.tagName !== 'TEXTAREA') {
    e.preventDefault();
    if (activeModal === 'item-modal') saveItemModal();
    else if (activeModal === 'risk-modal') saveRiskModal();
    else if (activeModal === 'stakeholder-modal') saveStakeholderModal();
  }
});
</script>
