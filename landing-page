    </div>
    <div class="projects-scroll">
      <div class="projects-grid" id="projects-grid">
        <!-- Cards rendered by JS -->
      </div>
    </div>
  </div>

  <!-- SETTINGS VIEW -->
  <div id="view-settings" style="display:none; flex-direction:column; flex:1; overflow:hidden;">
    <div class="main-header">
      <div class="main-header-row" style="margin-bottom:24px;">
        <div>
          <div class="main-header-title">Settings</div>
          <div class="main-header-sub">Manage your profile and preferences.</div>
        </div>
      </div>
    </div>
    <div class="settings-panel" id="settings-panel" style="display:block;">

      <!-- Profile -->
      <div class="settings-section">
        <div class="settings-section-header">
          <div class="settings-section-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <div class="settings-section-title">Profile</div>
            <div class="settings-section-sub">Your name and display preferences</div>
          </div>
        </div>
        <div class="settings-body">
          <div class="settings-field">
            <label>Display Name</label>
            <input type="text" id="setting-name" placeholder="Your name" oninput="updateSidebarPreview()" />
          </div>
          <div class="settings-field">
            <label>Role / Title</label>
            <input type="text" id="setting-role" placeholder="e.g. Project Manager" />
          </div>
          <div class="settings-field">
            <label>Email</label>
            <input type="email" id="setting-email" placeholder="your@email.com" />
          </div>
          <button class="settings-save" onclick="saveProfile()">Save Profile</button>
        </div>
      </div>

      <!-- Notifications placeholder -->
      <div class="settings-section">
        <div class="settings-section-header">
          <div class="settings-section-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          </div>
          <div>
            <div class="settings-section-title">Notifications</div>
            <div class="settings-section-sub">Email and in-app alert preferences</div>
          </div>
          <span class="settings-section-badge">Coming soon</span>
        </div>
        <div class="settings-placeholder">Notification settings will be available in a future update.</div>
      </div>

      <!-- Organisation placeholder -->
      <div class="settings-section">
        <div class="settings-section-header">
          <div class="settings-section-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div>
            <div class="settings-section-title">Organisation</div>
            <div class="settings-section-sub">Team members, roles and company details</div>
          </div>
          <span class="settings-section-badge">Coming soon</span>
        </div>
        <div class="settings-placeholder">Organisation management will be available when authentication is enabled.</div>
      </div>

      <!-- Billing placeholder -->
      <div class="settings-section">
        <div class="settings-section-header">
          <div class="settings-section-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <div>
            <div class="settings-section-title">Billing & Plan</div>
            <div class="settings-section-sub">Subscription, usage and invoices</div>
          </div>
          <span class="settings-section-badge">Coming soon</span>
        </div>
        <div class="settings-placeholder">Billing management will be available in a future update.</div>
      </div>

    </div>
  </div>

</main>

<!-- NEW PROJECT MODAL -->
<div class="modal-overlay" id="new-project-modal" style="display:none;" onclick="if(event.target===this)closeNewProjectModal()">
  <div class="new-project-modal" onclick="event.stopPropagation()">
    <div class="modal-top">
      <div class="modal-heading">Start a new project</div>
      <div class="modal-title-field">
        <label>Project Name</label>
        <input type="text" id="new-project-title" placeholder="e.g. Platform Redesign 2025" />
      </div>
    </div>
    <div class="modal-body">
      <div class="modal-body-label">Choose a template</div>
      <div class="template-grid" id="template-grid">
        <!-- Rendered by JS -->
      </div>
      <div class="modal-actions">
        <button class="modal-cancel" onclick="closeNewProjectModal()">Cancel</button>
        <button class="modal-create" id="modal-create-btn" onclick="createProject()" disabled>Create Project</button>
      </div>
    </div>
  </div>
</div>

<script type="module">
import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm';
const SUPABASE_URL  = 'https://bvzpoznolbnfehbsdghp.supabase.co';
const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ2enBvem5vbGJuZmVoYnNkZ2hwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM5MzU3OTUsImV4cCI6MjA4OTUxMTc5NX0.otdWCZfDFUgK5nLJmXUPlXFbUhJbTuh3VnL2OD0TH_c';
const sb = createClient(SUPABASE_URL, SUPABASE_ANON);

// ── STATE ──
let projects = [];
let activeFilter = 'all';
let selectedTemplate = null;

// ── TEMPLATES ──
const TEMPLATES = [
  {
    id: 'simple_agile',
    name: 'Simple Agile Project',
    icon: '⚡',
    iconBg: '#eef0ff',
    desc: 'Sprint-based delivery with iterative planning cycles and backlog management.',
  },
  {
    id: 'waterfall',
    name: 'Waterfall Project',
    icon: '🌊',
    iconBg: '#e8f4ff',
    desc: 'Sequential phase-gated delivery with formal sign-offs between stages.',
  },
  {
    id: 'product_launch',
    name: 'Product Launch',
    icon: '🚀',
    iconBg: '#fff0e8',
    desc: 'Go-to-market focused workflow from concept through launch and post-launch review.',
  },
  {
    id: 'it_infrastructure',
    name: 'IT Infrastructure',
    icon: '🖧',
    iconBg: '#e8ffe8',
    desc: 'Technical deployment pipeline for systems, networks and infrastructure rollouts.',
  },
  {
    id: 'org_change',
    name: 'Organisational Change',
    icon: '🔄',
    iconBg: '#fff8e0',
    desc: 'People and process transformation with stakeholder engagement focus.',
  },
  {
    id: 'research',
    name: 'Research & Discovery',
    icon: '🔍',
    iconBg: '#f0fff4',
    desc: 'Exploration and insight-driven projects with hypothesis testing cycles.',
  },
  {
    id: 'custom',
    name: 'Custom',
    icon: '✦',
    iconBg: '#f5f5f7',
    desc: 'Start with the standard project structure and customise from there.',
  },
];

// ── TOAST ──
function showToast(msg, type = 'ok') {
  let t = document.getElementById('landing-toast');
  if (!t) {
    t = document.createElement('div');
    t.id = 'landing-toast';
    t.style.cssText = `position:fixed;bottom:24px;left:50%;transform:translateX(-50%);padding:9px 20px;border-radius:9px;font-family:'Geist',sans-serif;font-size:12px;font-weight:500;z-index:9999;transition:opacity 0.3s;pointer-events:none;`;
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.background = type === 'error' ? '#c03030' : '#1a1a1f';
  t.style.color = '#fff';
  t.style.opacity = '1';
  clearTimeout(t._t);
  t._t = setTimeout(() => t.style.opacity = '0', 2200);
}

// ── LOAD PROJECTS ──
async function loadProjects() {
  const { data, error } = await sb
    .from('projects')
    .select('*')
    .order('created_at', { ascending: false });
  if (error) { showToast('Failed to load projects', 'error'); return; }
  projects = data || [];
  renderProjects();
}

// ── RENDER PROJECTS ──
function renderProjects() {
  const grid   = document.getElementById('projects-grid');
  const countEl = document.getElementById('project-count');

  const filtered = activeFilter === 'all'
    ? projects
    : projects.filter(p => (p.status || 'draft') === activeFilter);

  countEl.textContent = `${filtered.length} project${filtered.length !== 1 ? 's' : ''}`;

  if (!filtered.length) {
    grid.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <div class="empty-title">${activeFilter === 'all' ? 'No projects yet' : 'No ' + activeFilter.replace('_',' ') + ' projects'}</div>
        <div class="empty-sub">${activeFilter === 'all' ? 'Create your first project to get started. Choose a template and PM.Train will set up your graph.' : 'No projects match this filter.'}</div>
        ${activeFilter === 'all' ? `<button class="btn-new-project" onclick="openNewProjectModal()" style="margin-top:8px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          New Project
        </button>` : ''}
      </div>`;
    return;
  }

  grid.innerHTML = '';
  filtered.forEach((p, i) => {
    const status     = p.status || 'draft';
    const statusInfo = getStatusInfo(status);
    const dateStr    = p.end_date
      ? new Date(p.end_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
      : 'No end date set';

    const card = document.createElement('div');
    card.className = 'project-card';
    card.style.animationDelay = (i * 0.04) + 's';
    card.innerHTML = `
      <div class="card-top">
        <div class="card-title">${p.title || 'Untitled Project'}</div>
        <div class="status-badge ${statusInfo.cls}">
          <div class="status-dot"></div>
          ${statusInfo.label}
        </div>
      </div>
      <div class="card-meta">
        <div class="card-date">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Planned completion: ${dateStr}
        </div>
      </div>
      <div class="card-actions">
        <button class="card-btn primary" onclick="openGraph('${p.id}')">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><circle cx="4" cy="6" r="2"/><circle cx="20" cy="6" r="2"/><circle cx="4" cy="18" r="2"/><circle cx="20" cy="18" r="2"/><line x1="6" y1="6" x2="10" y2="11"/><line x1="18" y1="6" x2="14" y2="11"/><line x1="6" y1="18" x2="10" y2="13"/><line x1="18" y1="18" x2="14" y2="13"/></svg>
          Open Graph
        </button>
        <button class="card-btn" onclick="openStats('${p.id}')">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          Stats
        </button>
      </div>
    `;
    grid.appendChild(card);
  });
}

function getStatusInfo(status) {
  switch (status) {
    case 'in_progress':  return { cls: 'status-progress',   label: 'In Progress' };
    case 'complete':     return { cls: 'status-complete',   label: 'Complete' };
    case 'terminated':   return { cls: 'status-terminated', label: 'Terminated' };
    default:             return { cls: 'status-draft',      label: 'Draft' };
  }
}

// ── FILTER ──
function setFilter(filter, btn) {
  activeFilter = filter;
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  renderProjects();
}

// ── NAV ──
function showView(view) {
  document.getElementById('view-projects').style.display  = view === 'projects'  ? 'flex' : 'none';
  document.getElementById('view-settings').style.display  = view === 'settings'  ? 'flex' : 'none';
  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(el => {
    if (el.textContent.trim().toLowerCase().startsWith(view)) el.classList.add('active');
  });
}

// ── NEW PROJECT MODAL ──
function openNewProjectModal() {
  selectedTemplate = null;
  document.getElementById('new-project-title').value = '';
  document.getElementById('modal-create-btn').disabled = true;
  renderTemplates();
  document.getElementById('new-project-modal').style.display = 'flex';
  setTimeout(() => document.getElementById('new-project-title').focus(), 100);
}

function closeNewProjectModal() {
  document.getElementById('new-project-modal').style.display = 'none';
}

function renderTemplates() {
  const grid = document.getElementById('template-grid');
  grid.innerHTML = '';
  TEMPLATES.forEach(t => {
    const card = document.createElement('div');
    card.className = 'template-card';
    card.innerHTML = `
      <div class="template-icon" style="background:${t.iconBg}">${t.icon}</div>
      <div class="template-name">${t.name}</div>
      <div class="template-desc">${t.desc}</div>
    `;
    card.addEventListener('click', () => {
      document.querySelectorAll('.template-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      selectedTemplate = t;
      updateCreateBtn();
    });
    grid.appendChild(card);
  });
}

function updateCreateBtn() {
  const title = document.getElementById('new-project-title').value.trim();
  document.getElementById('modal-create-btn').disabled = !(title && selectedTemplate);
}

document.getElementById('new-project-title').addEventListener('input', updateCreateBtn);

async function createProject() {
  const title = document.getElementById('new-project-title').value.trim();
  if (!title || !selectedTemplate) return;

  const btn = document.getElementById('modal-create-btn');
  btn.textContent = 'Creating…';
  btn.disabled = true;

  const { data, error } = await sb
    .from('projects')
    .insert({ title, status: 'draft' })
    .select()
    .single();

  if (error || !data) {
    showToast('Failed to create project', 'error');
    btn.textContent = 'Create Project';
    btn.disabled = false;
    return;
  }

  closeNewProjectModal();
  // All templates load the same default graph for now
  window.location.href = `index.html?project=${data.id}`;
}

// ── OPEN GRAPH / STATS ──
function openGraph(id) {
  window.location.href = `index.html?project=${id}`;
}

function openStats(id) {
  showToast('Stats page coming soon');
}

// ── SETTINGS ──
function loadProfile() {
  try {
    const saved = JSON.parse(localStorage.getItem('pmtrain_profile') || '{}');
    if (saved.name)  { document.getElementById('setting-name').value  = saved.name;  updateSidebarPreview(); }
    if (saved.role)  document.getElementById('setting-role').value  = saved.role;
    if (saved.email) document.getElementById('setting-email').value = saved.email;
  } catch(e) {}
}

function updateSidebarPreview() {
  const name = document.getElementById('setting-name').value.trim();
  if (name) {
    document.getElementById('sidebar-user-name').textContent = name;
    document.getElementById('sidebar-avatar').textContent = name.charAt(0).toUpperCase();
  }
}

function saveProfile() {
  const profile = {
    name:  document.getElementById('setting-name').value.trim(),
    role:  document.getElementById('setting-role').value.trim(),
    email: document.getElementById('setting-email').value.trim(),
  };
  try { localStorage.setItem('pmtrain_profile', JSON.stringify(profile)); } catch(e) {}
  updateSidebarPreview();
  showToast('Profile saved');
}

// ── KEYBOARD ──
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeNewProjectModal();
});

// ── EXPOSE ──
Object.assign(window, {
  showView, openNewProjectModal, closeNewProjectModal,
  createProject, setFilter, openGraph, openStats, saveProfile, updateSidebarPreview,
});

// ── BOOT ──
loadProfile();
loadProjects();
</script>
</body>
</html>
