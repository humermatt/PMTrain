<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PM.Train</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Geist:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:      #f0f0f2;
    --bg2:     #ffffff;
    --bg3:     #e8e8eb;
    --border:  rgba(0,0,0,0.07);
    --border2: rgba(0,0,0,0.12);
    --text:    #1a1a1f;
    --text2:   #6b6a68;
    --text3:   #a0a09e;
    --accent:  #5a4fcf;
    --sidebar: #16151c;
    --sidebar2:#1f1e27;
    --sidebar3:#2a2935;

    --status-draft:      #e8e8eb;
    --status-draft-text: #6b6a68;
    --status-progress:   #1a2a4a;
    --status-progress-text: #7aaad8;
    --status-complete:   #1a3a2a;
    --status-complete-text: #5abf8a;
    --status-terminated: #e4e4e6;
    --status-terminated-text: #a0a09e;
  }

  html, body { height: 100%; overflow: hidden; }

  body {
    font-family: 'Geist', sans-serif;
    background: var(--bg);
    color: var(--text);
    display: flex;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    width: 220px;
    min-width: 220px;
    background: var(--sidebar);
    display: flex;
    flex-direction: column;
    height: 100vh;
    position: relative;
    z-index: 10;
  }

  .sidebar-brand {
    padding: 28px 24px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .sidebar-wordmark {
    font-family: 'Syne', sans-serif;
    font-size: 20px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.5px;
    line-height: 1;
  }
  .sidebar-wordmark span {
    color: var(--accent);
  }
  .sidebar-tagline {
    font-size: 10px;
    color: rgba(255,255,255,0.3);
    margin-top: 5px;
    letter-spacing: 0.04em;
    font-weight: 300;
  }

  .sidebar-nav {
    flex: 1;
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sidebar-nav-label {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    padding: 12px 12px 6px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    cursor: pointer;
    transition: all 0.15s;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }
  .nav-item:hover { background: var(--sidebar2); color: rgba(255,255,255,0.85); }
  .nav-item.active { background: var(--sidebar3); color: #fff; }
  .nav-item svg { flex-shrink: 0; opacity: 0.7; }
  .nav-item.active svg { opacity: 1; }

  .sidebar-footer {
    padding: 16px 12px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .sidebar-user {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .sidebar-user:hover { background: var(--sidebar2); }
  .sidebar-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: var(--accent);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: #fff;
    flex-shrink: 0;
  }
  .sidebar-user-name {
    font-size: 12px;
    color: rgba(255,255,255,0.7);
    font-weight: 400;
  }
  .sidebar-user-role {
    font-size: 10px;
    color: rgba(255,255,255,0.3);
  }

  /* ── MAIN ── */
  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow: hidden;
  }

  /* ── TOP HEADER ── */
  .main-header {
    padding: 32px 40px 0;
    flex-shrink: 0;
  }
  .main-header-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 24px;
  }
  .main-header-title {
    font-family: 'Syne', sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.7px;
    line-height: 1;
  }
  .main-header-sub {
    font-size: 13px;
    color: var(--text3);
    margin-top: 6px;
  }
  .btn-new-project {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    padding: 11px 20px;
    border-radius: 10px;
    border: none;
    background: var(--text);
    color: #fff;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: -0.2px;
    white-space: nowrap;
  }
  .btn-new-project:hover {
    background: #2e2e38;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.18);
  }

  /* ── FILTER BAR ── */
  .filter-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 40px 20px;
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .filter-chip {
    font-family: 'Geist', sans-serif;
    font-size: 12px;
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--border2);
    background: transparent;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-chip:hover { background: var(--bg2); }
  .filter-chip.active { background: var(--text); color: #fff; border-color: transparent; }
  .filter-sep { flex: 1; }
  .project-count {
    font-size: 11px;
    color: var(--text3);
  }

  /* ── PROJECT GRID ── */
  .projects-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 0 40px 40px;
  }
  .projects-scroll::-webkit-scrollbar { width: 6px; }
  .projects-scroll::-webkit-scrollbar-track { background: transparent; }
  .projects-scroll::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }

  /* ── PROJECT CARD ── */
  .project-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 24px 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: all 0.18s;
    position: relative;
    overflow: hidden;
    animation: card-in 0.3s ease both;
  }
  .project-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.09);
    border-color: var(--border2);
  }
  @keyframes card-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }
  .card-title {
    font-family: 'Syne', sans-serif;
    font-size: 16px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.3px;
    line-height: 1.25;
    flex: 1;
  }
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .status-dot { width: 5px; height: 5px; border-radius: 50%; }

  .status-draft     { background: var(--status-draft);     color: var(--status-draft-text); }
  .status-draft .status-dot { background: var(--status-draft-text); }
  .status-progress  { background: var(--status-progress);  color: var(--status-progress-text); }
  .status-progress .status-dot { background: var(--status-progress-text); }
  .status-complete  { background: var(--status-complete);  color: var(--status-complete-text); }
  .status-complete .status-dot { background: var(--status-complete-text); }
  .status-terminated{ background: var(--status-terminated);color: var(--status-terminated-text); }
  .status-terminated .status-dot { background: var(--status-terminated-text); }

  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .card-date {
    font-size: 11px;
    color: var(--text3);
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .card-template {
    font-size: 10px;
    color: var(--text3);
    display: flex;
    align-items: center;
    gap: 5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .card-actions {
    display: flex;
    gap: 8px;
    margin-top: 2px;
  }
  .card-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: 'Geist', sans-serif;
    font-size: 11px;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 8px;
    border: 1px solid var(--border2);
    background: transparent;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.15s;
    text-decoration: none;
  }
  .card-btn:hover { background: var(--bg); color: var(--text); }
  .card-btn.primary {
    background: var(--text);
    color: #fff;
    border-color: transparent;
  }
  .card-btn.primary:hover { background: #2e2e38; }

  /* ── EMPTY STATE ── */
  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .empty-icon {
    width: 64px; height: 64px;
    border-radius: 16px;
    background: var(--bg3);
    display: flex; align-items: center; justify-content: center;
    color: var(--text3);
  }
  .empty-title {
    font-family: 'Syne', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
  }
  .empty-sub { font-size: 13px; color: var(--text3); line-height: 1.6; max-width: 320px; }

  /* ── SETTINGS PANEL ── */
  .settings-panel {
    flex: 1;
    overflow-y: auto;
    padding: 0 40px 40px;
    display: none;
  }
  .settings-section {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 14px;
    margin-bottom: 16px;
    overflow: hidden;
  }
  .settings-section-header {
    padding: 18px 24px 14px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .settings-section-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: var(--bg3);
    display: flex; align-items: center; justify-content: center;
    color: var(--text2);
    flex-shrink: 0;
  }
  .settings-section-title {
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
  }
  .settings-section-sub {
    font-size: 11px;
    color: var(--text3);
    margin-top: 1px;
  }
  .settings-section-badge {
    margin-left: auto;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 20px;
    background: var(--bg3);
    color: var(--text3);
    border: 1px solid var(--border2);
  }
  .settings-body { padding: 20px 24px; }
  .settings-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 16px;
  }
  .settings-field:last-child { margin-bottom: 0; }
  .settings-field label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text3);
  }
  .settings-field input {
    font-family: 'Geist', sans-serif;
    font-size: 13px;
    color: var(--text);
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: 8px;
    padding: 9px 12px;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }
  .settings-field input:focus { border-color: rgba(0,0,0,0.25); }
  .settings-save {
    font-family: 'Geist', sans-serif;
    font-size: 12px;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: 8px;
    border: none;
    background: var(--text);
    color: #fff;
    cursor: pointer;
    transition: background 0.15s;
    margin-top: 4px;
  }
  .settings-save:hover { background: #2e2e38; }
  .settings-placeholder {
    padding: 32px 24px;
    text-align: center;
    color: var(--text3);
    font-size: 13px;
    font-style: italic;
  }

  /* ── NEW PROJECT MODAL ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
    animation: fade-in 0.15s ease;
  }
  @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }

  .new-project-modal {
    background: var(--bg2);
    border-radius: 18px;
    width: 720px;
    max-width: calc(100vw - 40px);
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 24px 80px rgba(0,0,0,0.22), 0 4px 16px rgba(0,0,0,0.1);
    animation: modal-up 0.2s cubic-bezier(0.34,1.4,0.64,1);
    display: flex;
    flex-direction: column;
  }
  @keyframes modal-up {
    from { opacity: 0; transform: translateY(16px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .modal-top {
    padding: 28px 32px 20px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .modal-heading {
    font-family: 'Syne', sans-serif;
    font-size: 20px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.4px;
    margin-bottom: 16px;
  }
  .modal-title-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .modal-title-field label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text3);
  }
  .modal-title-field input {
    font-family: 'Syne', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: 10px;
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.15s;
    letter-spacing: -0.3px;
  }
  .modal-title-field input:focus { border-color: var(--accent); }
  .modal-title-field input::placeholder { color: var(--text3); font-weight: 700; }

  .modal-body {
    padding: 24px 32px 32px;
    flex: 1;
  }
  .modal-body-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 16px;
  }

  /* Template grid */
  .template-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }
  .template-card {
    border: 2px solid var(--border);
    border-radius: 12px;
    padding: 18px 16px;
    cursor: pointer;
    transition: all 0.15s;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
  }
  .template-card:hover {
    border-color: var(--border2);
    background: var(--bg2);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
  }
  .template-card.selected {
    border-color: var(--accent);
    background: var(--bg2);
    box-shadow: 0 0 0 3px rgba(90,79,207,0.12);
  }
  .template-card.selected::after {
    content: '✓';
    position: absolute;
    top: 10px; right: 12px;
    width: 20px; height: 20px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 20px;
    text-align: center;
  }
  .template-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }
  .template-name {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.2px;
    line-height: 1.25;
  }
  .template-desc {
    font-size: 11px;
    color: var(--text3);
    line-height: 1.5;
  }

  .modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding-top: 4px;
    border-top: 1px solid var(--border);
    margin-top: 4px;
  }
  .modal-cancel {
    font-family: 'Geist', sans-serif;
    font-size: 13px;
    padding: 10px 20px;
    border-radius: 9px;
    border: 1px solid var(--border2);
    background: transparent;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.15s;
  }
  .modal-cancel:hover { background: var(--bg3); }
  .modal-create {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    padding: 10px 24px;
    border-radius: 9px;
    border: none;
    background: var(--text);
    color: #fff;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: -0.2px;
  }
  .modal-create:hover { background: #2e2e38; }
  .modal-create:disabled { opacity: 0.4; cursor: not-allowed; }
</style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="sidebar-wordmark">PM<span>.</span>Train</div>
    <div class="sidebar-tagline">Project management, simplified</div>
  </div>

  <nav class="sidebar-nav">
    <div class="sidebar-nav-label">Workspace</div>
    <button class="nav-item active" onclick="showView('projects')">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      Projects
    </button>
    <div class="sidebar-nav-label">Account</div>
    <button class="nav-item" onclick="showView('settings')">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      Settings
    </button>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user" onclick="showView('settings')">
      <div class="sidebar-avatar" id="sidebar-avatar">U</div>
      <div>
        <div class="sidebar-user-name" id="sidebar-user-name">User</div>
        <div class="sidebar-user-role">Project Manager</div>
      </div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<main class="main">

  <!-- PROJECTS VIEW -->
  <div id="view-projects" style="display:flex; flex-direction:column; flex:1; overflow:hidden;">
    <div class="main-header">
      <div class="main-header-row">
        <div>
          <div class="main-header-title">Projects</div>
          <div class="main-header-sub">Manage and track all your active projects.</div>
        </div>
        <button class="btn-new-project" onclick="openNewProjectModal()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          New Project
        </button>
      </div>
      <div class="filter-bar">
        <button class="filter-chip active" onclick="setFilter('all', this)">All</button>
        <button class="filter-chip" onclick="setFilter('draft', this)">Draft</button>
        <button class="filter-chip" onclick="setFilter('in_progress', this)">In Progress</button>
        <button class="filter-chip" onclick="setFilter('complete', this)">Complete</button>
        <button class="filter-chip" onclick="setFilter('terminated', this)">Terminated</button>
        <div class="filter-sep"></div>
        <span class="project-count" id="project-count"></span>
